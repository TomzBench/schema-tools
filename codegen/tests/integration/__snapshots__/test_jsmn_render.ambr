      const struct parent *src)
  {
  	return schema_encode(dst, dlen, src, ST_STRUCT(SCHEMA_PARENT_KEY));
  }
  
  int32_t
  schema_decode_sibling_tok(
      struct sibling *dst,
      const char *src,
      uint32_t slen,
      jsmntok_t *toks,
      uint32_t ntoks)
  {
      return schema_decode(toks, ntoks, dst, ST_STRUCT(SCHEMA_SIBLING_KEY), src, slen);
  }
  
  int32_t
  schema_decode_sibling(
      struct sibling *dst,
      const char *src,
      uint32_t slen)
  {
      jsmntok_t toks[3];
      return schema_decode_sibling_tok(dst, src, slen, toks, 3);
  }
  
  int32_t
  schema_encode_sibling(
      uint8_t *dst,
      uint32_t dlen,
      const struct sibling *src)
  {
  	return schema_encode(dst, dlen, src, ST_STRUCT(SCHEMA_SIBLING_KEY));
  }
  
  
  '''
