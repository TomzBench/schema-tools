{# --- Prototype declarations --- #}
{% macro decode_prototype(prefix, name, qual="") %}
int32_t {{ prefix }}decode_{{ name }}_tok(
    {{ (qual ~ ' ' ~ name) | trim }} *dst,
    const char *src,
    uint32_t slen,
    jsmntok_t *toks,
    uint32_t ntoks);

int32_t {{ prefix }}decode_{{ name }}(
    {{ (qual ~ ' ' ~ name) | trim }} *dst,
    const char *src,
    uint32_t slen);
{%- endmacro %}

{% macro encode_prototype(prefix, name, qual="") %}
int32_t {{ prefix }}encode_{{ name }}(
    uint8_t *dst,
    uint32_t dlen,
    const {{ (qual ~ ' ' ~ name) | trim }} *src);
{%- endmacro %}

{% macro encode_len(prefix) %}
uint32_t {{ prefix }}encode_len_prototype(int idx, struct rt_schemas *schemas);
{%- endmacro %}

{# --- Implementation --- #}
{% macro decode(prefix, name, ntoks, type_expr, schemas, qual="") %}
int32_t
{{ prefix }}decode_{{ name }}_tok(
    {{ (qual ~ ' ' ~ name) | trim }} *dst,
    const char *src,
    uint32_t slen,
    jsmntok_t *toks,
    uint32_t ntoks)
{
    return rt_decode(&{{ schemas }}, toks, ntoks, dst, {{ type_expr }}, src, slen);
}

int32_t
{{ prefix }}decode_{{ name }}(
    {{ (qual ~ ' ' ~ name) | trim }} *dst,
    const char *src,
    uint32_t slen)
{
    jsmntok_t toks[{{ ntoks }}];
    return {{ prefix }}decode_{{ name }}_tok(dst, src, slen, toks, {{ ntoks }});
}
{%- endmacro %}

{% macro encode(prefix, name, type_expr, schemas, qual="") %}
int32_t
{{ prefix }}encode_{{ name }}(
    uint8_t *dst,
    uint32_t dlen,
    const {{ (qual ~ ' ' ~ name) | trim }} *src)
{
	return rt_encode(&{{ schemas }}, dst, dlen, src, {{ type_expr }});
}
{%- endmacro %}

{% macro encode_len_impl(prefix, schemas) %}
uint32_t
{{ prefix }}encode_len(int idx, struct rt_schemas *schemas)
{
	return schemas->structs[idx].encode_len;
}
{%- endmacro %}
